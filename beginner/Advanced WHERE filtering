    (prod.vend_id ='DLL01'OR prod.vend_id ='BRS01') AND prod.prod_price > 10
;
#Q4:What are the products from vendors excluding those with the id of DLL01?
SELECT
prod.prod_id,
prod.prod_name,
prod.prod_price,
prod.vend_id
FROM
  `brjo4089.styssql.products` AS prod
WHERE 
    NOT prod.vend_id = 'DLL01'
;
#Q5: WHat are all our producys that start with "Fish"?
SELECT
prod.prod_id,
prod.prod_name,
prod.prod_price,
prod.vend_id
FROM
  `brjo4089.styssql.products` AS prod
WHERE 
    prod.prod_name LIKE 'Fish%'
;
