# Q1-Q7: SQL Advanced Data Filtering

#Q1: What are all the products with a vendor id of DLL01 and a price of $4 or less?

SELECT
prod.prod_id,
prod.prod_name,
prod.prod_price,
prod.vend_id
FROM
  `brjo4089.styssql.products` AS prod
WHERE
    prod.vend_id = 'DLL01' AND prod.prod_price <=4
;
#Q2: What are all the products from the venfors with Ids of DLL01 or BRS01?
SELECT
prod.prod_id,
prod.prod_name,
prod.prod_price,
prod.vend_id
FROM
  `brjo4089.styssql.products` AS prod
WHERE
    prod.vend_id = 'DLL01' OR prod.vend_id = 'BRS01'
;
#Q2b. same question but different approach
SELECT
prod.prod_id,
prod.prod_name,
prod.prod_price,
prod.vend_id
FROM
  `brjo4089.styssql.products` AS prod
WHERE
    prod.vend_id IN ('DLL01','BRS01') -- This is the same as doing the OR statement on line 24
;
#Q3: What are all the products we source from the vendors wth ids of DLL01 and BRS01 that have prices above $10?
