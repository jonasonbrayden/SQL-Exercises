#Q5: What is the average monthly ship speed in January and February for ship courses 1 and 2?  
SELECT
  ship.month,
  ship.ship_course,
  ROUND(AVG(ship.ship_speed),2) AS avg_speed
FROM
  `bigquery-public-data.noaa_icoads.icoads_core_2016` AS ship
WHERE
  ship.month = 1 OR ship.month = 2
GROUP BY
  ship.month,
  ship.ship_course
HAVING
  ship.ship_course = 1 OR ship.ship_course =2
;
#Q6: What was the average damage (in millions of dollars) for earthquakes in Italy?
SELECT
  ROUND(AVG(dam.damage_millions_dollars), 2) AS avgDamage,
  dam.country
FROM
  `bigquery-public-data.noaa_significant_earthquakes.earthquakes` AS dam
WHERE
  dam.country = "ITALY"
GROUP BY
  dam.country
  ;
#Q7: What was the average damage in millions of dollars in Italy for earthquakes between the years 2010 and 2015 that had a primary magnitude greater than 4? 
SELECT DISTINCT
  ROUND(AVG(dam.damage_millions_dollars), 2) AS avgDamage,
  dam.country,
  dam.year,
  dam.eq_primary
FROM
  `bigquery-public-data.noaa_significant_earthquakes.earthquakes` AS dam
WHERE
  dam.country = "ITALY" AND dam.year BETWEEN 2010 AND 2015
GROUP BY
  dam.country,
  dam.year,
  dam.eq_primary
HAVING
  dam.eq_primary > 4
;
#Q8: How many zip codes have an average male population across all age segments greater than 2000 and a total male population greater than 50,000?
SELECT
  COUNT(male.zipcode) AS zipcode,
  ROUND(AVG(male.population), 2) AS avgPop,
  COUNT(male.population) AS totPop,
FROM
  `bigquery-public-data.census_bureau_usa.population_by_zip_2010` AS male
WHERE
  male.gender = "male"
GROUP BY
  male.zipcode
HAVING
  avgPop > 2000 AND totPop >50000
ORDER BY
  totPop DESC,
  male.zipcode DESC
  ;
