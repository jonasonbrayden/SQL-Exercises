  ;
  #Q3: What was the average sea level pressure in June rounded to 2 decimal places?
SELECT
  p.month,
  ROUND(AVG(p.sea_level_pressure),2) AS avgSeaLevel
FROM
  `bigquery-public-data.noaa_icoads.icoads_core_2016` AS p
WHERE
  p.month = 6
GROUP BY
  p.month
;
