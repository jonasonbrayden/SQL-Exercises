pop.zipcode,
pop.population AS zipPop,
  (SELECT SUM(pop.population)
  FROM `bigquery-public-data.census_bureau_usa.population_by_zip_2010`AS pop
  WHERE
  pop.gender IS NULL
  AND
  pop.zipcode IN("80301", "80302", "80303", "80304", "80310")
  ) AS totPop,
pop.population/
    (SELECT(SUM(pop.population)) 
