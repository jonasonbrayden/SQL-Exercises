    #What is the total population in each of the Boulder zipcodes 80301, 80302, 80303, 80304, and 80310 and the total population for all those zipcodes combined
SELECT
pop.zipcode,
pop.population AS zipPop,
(SELECT SUM(pop.population)
FROM `bigquery-public-data.census_bureau_usa.population_by_zip_2010`AS pop
WHERE
pop.gender IS NULL
AND
pop.zipcode IN("80301", "80302", "80303", "80304", "80310")
) AS totPop
FROM
  `bigquery-public-data.census_bureau_usa.population_by_zip_2010` AS pop
WHERE
pop.zipcode IN("80301", "80302", "80303", "80304", "80310")
AND
pop.gender IS NULL
GROUP BY
pop.population,
pop.zipcode
;
#Q2: Which months had an average monthly air temperature greater than the overall average air temperature?
--Show the months, monthly average, and overall average in the same result set/output
--Round the results to 1 decimal place
--Alias the monthly average air temperature as moAvgTemp
--Alias the overall average air temperature as ovAvgTemp
--Sort the results in descending order by monthly average air temperature
SELECT
icoad.month,
ROUND((AVG(icoad.air_temperature)),2) AS moAvgTemp,
(SELECT 
ROUND(AVG(icoad_sub.air_temperature)) AS ovAvgTemp
FROM
`bigquery-public-data.noaa_icoads.icoads_core_2017` AS icoad_sub
) AS overall_avg_air_temp
FROM
  `bigquery-public-data.noaa_icoads.icoads_core_2017` AS icoad
GROUP BY
icoad.month
HAVING
moAvgTemp> overall_avg_air_temp
ORDER BY
moAvgTemp DESC
;
#Q3: (Reference Question1)  What is each of Boulder's zip codes proportion of the total?
