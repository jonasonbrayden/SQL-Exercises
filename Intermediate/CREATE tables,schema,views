#view to simplify the process of filtering products
CREATE VIEW
`styssql.prodCustJoin`
AS
SELECT
cust.cust_name,
cust.cust_contact,
ordI.prod_id
FROM
`brjo4089.styssql.customers` AS cust
INNER JOIN
`brjo4089.styssql.orders` AS ord
ON
cust.cust_id = ord.cust_id
INNER JOIN
`brjo4089.styssql.order_items` AS ordI
ON
ord.order_num = ordI.order_num

;
#Question: Who are all the customers that ordered product 'RGAN01'?
SELECT
  *
FROM
  `culeeds.stssql.prodCustJoin` AS prodview
WHERE 
prodview.prod_id - 'RGAN01'
;
