#Q1: Create the subset Classic Rock table from listenbrainz dataset. 
#For now, restrict the artist names being stored in this table to the following string literals :  'Led Zeppelin','AC/DC','ZZ Top','Def Leppard'

CREATE OR REPLACE TABLE
`brjo4089.mydb.classicrock`
AS
  SELECT
  *
  FROM
  `brjo4089.listenbrainz.listen`
WHERE
artist_name IN('Led Zeppelin', 'AC/DC', 'ZZ Top', 'Def Leppard')

;
#Q2: Complete the SQL code that would insert 3 new artists from the listenbrainz dataset to the mydb.classicrock table. Insert the following artists: Creedence Clearwater Revival, Kiss, Steve Miller Band


INSERT INTO
`brjo4089.mydb.classicrock`
SELECT *
FROM
`listenbrainz.listenbrainz.listen`
WHERE
artist_name IN('Creedence Clearwater Revival', 'Kiss', 'Steve Miller Band')

;
#Q3: Now, add a column to the classicrock table named, genre, so we can store the musical genre in our dataset.
