# Using the SaleCo database, create a view, vProduct, that does the following for each vendor
CREATE VIEW
  `brjo4089.SaleCo.vProduct`
AS
SELECT

  CASE WHEN CAST(vend.V_CODE AS STRING) IS NULL THEN 'In-House'ELSE CAST(vend.   V_CODE AS STRING) END AS vcode,
  CASE WHEN V_NAME IS NULL THEN 'In-House'ELSE V_NAME END AS vname,
  V_CONTACT,
  COUNT(DISTINCT P_CODE) AS vendProds,
  P_PRICE*P_QOH AS vendValue,
  MAX(P_QOH) AS maxQty,
  MIN(P_QOH) AS minQty,
  ROUND(AVG(P_QOH),2) AS avgQty

FROM
  `brjo4089.SaleCo.vendor` AS vend
INNER JOIN
  `brjo4089.SaleCo.product` AS prod
ON
vend.v_code = prod.v_code

GROUP BY
ROLLUP (vend.v_code,V_NAME,
vend.V_CODE,
V_NAME,
P_PRICE,
P_QOH,
V_CONTACT)
;
SELECT
*
FROM
  `brjo4089.SaleCo.vProduct`
ORDER BY
vendValue DESC
;
