#Views can be used for calculated fields
CREATE VIEW
`styssql.totCost`
AS
SELECT
*,
ROUND(ordI.quantity * ordI.item_price, 2) AS totCost
FROM
`styssql.order_items` AS ordi
;
SELECT
*
FROM
`styssql.totCost`
