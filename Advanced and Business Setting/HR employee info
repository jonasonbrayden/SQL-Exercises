# Q3:What is the average years (EMP_YEARS) of employment for employees whose last names start with 'A'?
SELECT
  AVG(EMP_YEARS) AS avgyears,
  emp.EMP_LNAME,
  SUM(EMP_YEARS) AS totalyears,
  
FROM
  `brjo4089.ConstrucCO.employee` AS emp
WHERE
  emp.EMP_LNAME LIKE "A%"
  GROUP BY
  emp.EMP_LNAME
;
