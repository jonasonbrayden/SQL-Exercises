# Q6:Which users listened to both "Dolly Parton" more than 50 times and "Madonna" more than 50 times? 
SELECT
user_name,
AVG(d_listens),
COUNT(list.listened_at)
FROM
  `brjo4089.listenbrainz.listen` AS list
  INNER JOIN
  (
  SELECT
  artist_name,
  user_name,
  COUNT(listened_at) AS d_listens
  FROM
  `brjo4089.listenbrainz.listen` 
  WHERE
  artist_name = "Dolly Parton"
  GROUP BY
  artist_name,
  user_name
  HAVING 
  d_listens > 50
  ORDER BY
  d_listens DESC
) AS view1
;
