#Q4: As of 4/1/2022, what are the total and average cases, deaths, and population for Colorado and California? 
SELECT
  state  AS ST,
  county_name AS county,
  SUM(CASE WHEN date = '2022-4-01' THEN confirmed_cases END) AS totCases,
  SUM(CASE WHEN date = '2022-4-01' THEN deaths END) AS totDeaths,
  SUM(CASE WHEN date = '2022-4-01' THEN population END) AS totPop,
  AVG(CASE WHEN date = '2022-4-01' THEN confirmed_cases END) AS avgCases,
  AVG(CASE WHEN date = '2022-4-01' THEN deaths END) AS avgDeaths,
  AVG(CASE WHEN date = '2022-4-01' THEN population END) AS avgPop
FROM
  `brjo4089.mydb.dw_covid19`
WHERE
state = "CO" OR state= "CA"
GROUP BY
ROLLUP(state,
county_name)
ORDER BY
totCases DESC
;
#Q5: As of 2/1/2022, what were the total cases for each time zone? 
SELECT
  timeZone,
  SUM(CASE WHEN date = '2022-2-01' THEN confirmed_cases END) AS totCases,
  SUM(CASE WHEN date = '2022-2-01' THEN deaths END) AS totDeaths,
  SUM(CASE WHEN date = '2022-2-01' THEN population END) AS totPop,
 (SELECT SUM(CASE WHEN date = '2022-4-01' THEN confirmed_cases END)/SUM    (CASE WHEN date = '2022-4-01' THEN population END) *100000
  FROM `brjo4089.mydb.dw_covid19`) AS casesper100k,
  (SELECT SUM(CASE WHEN date = '2022-4-01' THEN deaths END)/SUM(CASE WHEN   date = '2022-4-01' THEN population END) *100000
  FROM `brjo4089.mydb.dw_covid19`) AS deathsper100k

FROM
  `brjo4089.mydb.dw_covid19`
  GROUP BY
 timeZone
 ORDER BY
 casesper100k DESC
;
#Q1:What is the total customer revenue per invoice?
SELECT
  IFNULL(cus.CUS_LNAME,'Grand Total') AS name,
  IFNULL(CAST(inv.INV_NUMBER AS STRING), 'Cust Total') AS invoice, 
  ROUND(SUM(cus.CUS_BALANCE),2) AS revenue

FROM
  `brjo4089.SaleCo.customer` AS cus
INNER JOIN
  `brjo4089.SaleCo.invoice` AS inv
ON
  cus.CUS_CODE = inv.CUS_CODE
GROUP BY
  ROLLUP(
    cus.CUS_LNAME,
    inv.INV_NUMBER
  )
ORDER BY
  revenue DESC,
  name
;
#Q3: What were the assignment charges for each project as well as the running total assignment charges?
SELECT
  proj.proj_num,
  proj.proj_name,
  assign.assign_num,
  SUM(assign.ASSIGN_CHARGE) OVER(
    PARTITiON BY proj.PROJ_NUM
    ORDER BY assign.ASSIGN_NUM
    ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
   ) AS assign_chg_running_total,
  ROUND(SUM(assign.ASSIGN_CHARGE),2) AS ASSIGN_CHARGE
  
FROM
  `brjo4089.ConstrucCO.project` AS proj
INNER JOIN
  `brjo4089.ConstrucCO.assignment` AS assign
ON
  proj.proj_num = assign.proj_num
GROUP BY
  proj.proj_num,
  proj.proj_name,
  assign.assign_num,
  assign.ASSIGN_CHARGE
ORDER BY
  proj.PROJ_NUM,
  assign.ASSIGN_NUM 
