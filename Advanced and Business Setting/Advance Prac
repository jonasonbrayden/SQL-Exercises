#Q7: In 2015, what boros had at least 600 "hawthorn" trees and at least 1000 "honeylocust" trees? 
SELECT DISTINCT
  tree.borocode,
  tree.boroname, 
  hawtree.haw_trees,
  loctree.loc_trees,
FROM
(SELECT
  boroname,
  COUNT(tree_id) AS loc_trees
  FROM`bigquery-public-data.new_york_trees.tree_census_2015` 
  WHERE
  spc_common = "honeylocust" AND EXTRACT(YEAR FROM created_at) = 2015
  GROUP BY
  boroname
  HAVING
  loc_trees >=1000) AS loctree
INNER JOIN
  (SELECT
  boroname,
  COUNT(tree_id) AS haw_trees
  FROM`bigquery-public-data.new_york_trees.tree_census_2015` 
  WHERE
  spc_common = "hawthorn" AND EXTRACT(YEAR FROM created_at) = 2015
  GROUP BY
  boroname
  HAVING
  haw_trees >=600) AS hawtree
ON
  loctree.boroname =hawtree.boroname
INNER JOIN
  `bigquery-public-data.new_york_trees.tree_census_2015` AS tree
ON 
  tree.boroname = hawtree.boroname
ORDER BY
  boroname DESC
;
SELECT
  tree.boroname,
  COUNT(tree.tree_id) AS haw_trees
FROM
  `bigquery-public-data.new_york_trees.tree_census_2015` AS tree
WHERE
  spc_common = "hawthorn" AND EXTRACT(YEAR FROM created_at) = 2015
GROUP BY
  tree.boroname
HAVING
  haw_trees >=600
;
SELECT
  tree.boroname,
  COUNT(tree.tree_id) AS loc_trees
FROM
  `bigquery-public-data.new_york_trees.tree_census_2015` AS tree
WHERE
  spc_common = "honeylocust" AND EXTRACT(YEAR FROM created_at) = 2015
GROUP BY
  tree.boroname
HAVING
  loc_trees >=1000
;
