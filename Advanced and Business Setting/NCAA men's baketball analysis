#Q1:What are the 2 most common mascots?
SELECT
  mas.mascot,
  COUNT(mascot) AS occur

FROM
  `brjo4089.ncaa_basketball.mascots` AS mas
GROUP BY
  mas.mascot
ORDER BY
  occur DESC
  ;
#Q2: How many Venues have greater than 22000 seats?  and What is the venue name of the venue with the THIRD most seats?
SELECT
  ven.venue_name,
  ven.venue_capacity
FROM
  `brjo4089.ncaa_basketball.mbb_teams` AS ven
WHERE
  ven.venue_capacity > 22000
ORDER BY
ven.venue_capacity DESC
;
#Q5: How many mascots are there whose name of the university's team starts with the letter 'B' and are from the non-Linnean type of being or creature of 'Aristocrats'?
SELECT
  b.name,
  b.non_tax_type
FROM
  `bigquery-public-data.ncaa_basketball.mascots` AS b
WHERE
  b.name LIKE 'B%'
  AND
  b.non_tax_type = 'Aristocrats'
;
#Q3: How many unique mascots are there?
SELECT DISTINCT
  m.mascot
FROM
  `bigquery-public-data.ncaa_basketball.mascots` AS m
;

