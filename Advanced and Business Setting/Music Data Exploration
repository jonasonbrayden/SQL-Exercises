#What are Janis Joplins most popular songs?
SELECT
list.artist_name,
list.track_name,
COUNT(list.listened_at) AS listens
FROM
  `brjo4089.listenbrainz.listen` AS list
WHERE
artist_name = "Janis Joplin"
GROUP BY
list.artist_name,
list.track_name
ORDER BY
listens DESC
;
