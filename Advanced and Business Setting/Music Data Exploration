SELECT
artist_name,
COUNT(listened_at) AS artist_listens,
COUNT(DISTINCT user_name) AS fans,
ROUND(COUNT(listened_at)/ COUNT(DISTINCT user_name), 2) AS avg_listens_per_fan
FROM
  `brjo4089.listenbrainz.listen`
  WHERE
  artist_name IN( "Whitney Houston", "Mariah Carey", "Beyonce", "Dixie Chicks", "Madonna", "Ella Fitzgerald", "Aretha Franklin", "Dolly Parton", "Lady Gaga", "Shania Twain", "Lizzo")
  GROUP BY
  artist_name
  ORDER BY
  artist_listens DESC
