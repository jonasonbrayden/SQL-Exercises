#CORRECT ANSWER USING IN-LINE VIEW
SELECT
artist_name,
SUM(listens) AS totlistens,
ROUND(AVG(listens),2) AS avgUserListens

FROM

(
  SELECT
  artist_name,
  user_name,
  COUNT(listened_at) AS listens
  FROM
  `brjo4089.listenbrainz.listen`
  WHERE
  artist_name = "Mariah Carey"
  GROUP BY
  artist_name,
  user_name
  ORDER BY
  listens DESC
) AS view1

GROUP BY
artist_name
ORDER BY
totlistens DESC
;
