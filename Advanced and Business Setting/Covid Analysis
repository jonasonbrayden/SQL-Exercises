  timeZone,
  SUM(CASE WHEN date = '2022-2-01' THEN confirmed_cases END) AS totCases,
  SUM(CASE WHEN date = '2022-2-01' THEN deaths END) AS totDeaths,
  SUM(CASE WHEN date = '2022-2-01' THEN population END) AS totPop,
 (SELECT SUM(CASE WHEN date = '2022-4-01' THEN confirmed_cases END)/SUM    (CASE WHEN date = '2022-4-01' THEN population END) *100000
  FROM `brjo4089.mydb.dw_covid19`) AS casesper100k,
  (SELECT SUM(CASE WHEN date = '2022-4-01' THEN deaths END)/SUM(CASE WHEN   date = '2022-4-01' THEN population END) *100000
  FROM `brjo4089.mydb.dw_covid19`) AS deathsper100k

