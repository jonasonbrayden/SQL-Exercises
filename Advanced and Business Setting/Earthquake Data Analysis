#You've been asked to collect data on Earthquakes across the Globe. They want you to create a view with the following information:
  CREATE VIEW
    `brjo4089.mydb.eqChallenge`
  AS
  SELECT
  year,
  country,
  COUNT(id) as EQs,
  total_deaths,
  total_injuries,
  CASE
    WHEN flag_tsunami IS NOT NULL THEN 1
    ELSE NULL
  END AS Tsunami_flag,
  CASE
    WHEN country IN ([ENTER SOUTH AMERICAN COUNTRIES HERE]) THEN 'South America'
    WHEN country IN ([ENTER NORTH AMERICAN COUNTRIES HERE]) THEN 'North America'
    WHEN country IN ([ENTER EUROPEAN COUNTRIES HERE]) THEN 'Europe'
    ELSE 'Other'
  END AS continent,
  CASE 
    WHEN total_deaths IS NULL THEN NULL
    WHEN SUM(total_deaths) > (SELECT ROUND(AVG(total_deaths),2) FROM `bigquery-public-data.noaa_significant_earthquakes.earthquakes`) THEN 1
    ELSE 0
  END AS High_death_flag,
  CASE 
    WHEN total_injuries IS NULL THEN NULL 
    WHEN SUM(total_injuries) > (SELECT ROUND(AVG(total_injuries),2) FROM `bigquery-public-data.noaa_significant_earthquakes.earthquakes`) THEN 1
    ELSE 0
  END AS High_injuries_flag
FROM 
  `bigquery-public-data.noaa_significant_earthquakes.earthquakes`
GROUP BY
  year, 
  country,
  flag_tsunami,
  total_deaths,
  total_injuries
  ;
  #How many total earthquakes where have there been in our "v_EqChallenge" view?
  SELECT
  COALESCE(continent,'GRAND TOTAL') AS continents,
  COALESCE(country,'CONTINENT TOTAL') AS countries, 
  SUM(EQs) AS totalEQs,
  SUM(Tsunami_flag) AS totTsunami,
  SUM(High_death_flag) AS totHighDeath,
  SUM(total_deaths) AS totDeath,
  ROUND(AVG(total_deaths),2) AS avgDeaths,
  SUM(High_injuries_flag) AS totHighInjuries,
  SUM(total_injuries) AS totInjuries,
  ROUND(AVG(total_deaths),2) AS avgInjuries
FROM
  `elite-totality-301818.mydb.eqChallenge`
WHERE
  year >= 1800
GROUP BY 
  ROLLUP(continent,country)
ORDER BY
  totalEQs DESC,
  continent
;
#Q6: What was the average damage (in millions of dollars) for earthquakes in Italy?
SELECT
  ROUND(AVG(dam.damage_millions_dollars), 2) AS avgDamage,
  dam.country
FROM
  `bigquery-public-data.noaa_significant_earthquakes.earthquakes` AS dam
WHERE
  dam.country = "ITALY"
GROUP BY
  dam.country
  ;
#Q7: What was the average damage in millions of dollars in Italy for earthquakes between the years 2010 and 2015 that had a primary magnitude greater than 4? 
SELECT DISTINCT
  ROUND(AVG(dam.damage_millions_dollars), 2) AS avgDamage,
  dam.country,
  dam.year,
  dam.eq_primary
FROM
  `bigquery-public-data.noaa_significant_earthquakes.earthquakes` AS dam
WHERE
  dam.country = "ITALY" AND dam.year BETWEEN 2010 AND 2015
GROUP BY
  dam.country,
  dam.year,
  dam.eq_primary
HAVING
  dam.eq_primary > 4
;
#Q4: How many hurricanes were there in 1990 whose names started with either A or B?
SELECT DISTINCT
  f.season,
  f.name
FROM
  `bigquery-public-data.noaa_hurricanes.hurricanes` AS f
WHERE
  (f.name LIKE 'A%' 
  OR
  f.name LIKE'B%')
  AND
  f.season = '1990'
  #A: 11
;
#Q5: What are the names of the hurricanes that occurred in 1990 whose names started with either A or B?
SELECT DISTINCT
  f.season,
  f.name
FROM
  `bigquery-public-data.noaa_hurricanes.hurricanes` AS f
WHERE
  (f.name LIKE 'A%' 
  OR
  f.name LIKE'B%')
  AND
  f.season = '1990'
  ORDER BY 
  f.name ASC
