#What is the vendor average units sold per invoice?
#Show vendor code and vendor name for all vendors as well as the average units sold per invoice for any in-house products (i.e., no vendor info)
#Calculate and return the total number of invoices for each vendor, the total quantity for each vendor, and the average per invoice for each vendor
#Calculate the overall average units sold per invoice for the SaleCo company.
#Sort the results by vendor average in descending order
SELECT
vend.V_CODE,
vend.V_NAME,
COUNT(DISTINCT line.INV_NUMBER ) AS numInvoices,
SUM(line.LINE_UNITS) AS vend_units,
ROUND(SUM(line.line_units)/ COUNT(DISTINCT line.inv_number), 2) AS vendAVG,

(SELECT
(SUM(line.line_units)/ COUNT(DISTINCT line.inv_number))
FROM
`brjo4089.SaleCo.line` AS line
) AS SalecoavgUnits
FROM
  `brjo4089.SaleCo.line` AS line
INNER JOIN
  `brjo4089.SaleCo.product` AS prod
ON
  line.P_CODE=prod.P_CODE
LEFT JOIN 
  `brjo4089.SaleCo.vendor` AS vend
ON
prod.V_CODE = vend.V_CODE
GROUP BY 
vend.V_CODE,
vend.V_NAME
ORDER BY
vendAVG DESC
;
