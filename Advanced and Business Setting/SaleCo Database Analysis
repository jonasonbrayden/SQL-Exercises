#What are the total product sales and the employee contribution to the product sales?
--The employee table is not shown in the ERD because it serves a different purpose in SaleCo's overall data structure. Use the employee table (not emp) for this problem in addition to any other tables that are shown in the ERD
--Show product code, the product sales as pSales, the employee count as eCount, and the employee contribution as eContrib
--Employee contribution (eContrib) is the amount of product sales per employee
--Use an in-line view to answer this question
--There may be other ways to answer the question but the main objective of this question is for you to practice in-line views 
--Sort the results by product sales in descending order
SELECT
prodsummary.p_code,
prodsummary.psales,
prodsummary.eCount,
ROUND(pSales/eCount, 2) AS eContrib

FROM
(SELECT
p_code,
SUM (LINE_UNITS*LINE_PRICE) AS pSales,

(SELECT
COUNT(EMP_NUM)
FROM
`brjo4089.SaleCo.employee`) AS eCount

FROM `brjo4089.SaleCo.line`
GROUP BY
P_CODE
) AS prodsummary

ORDER BY
pSales DESC

;
#Who are the customers (if any) that purchased both the products with product codes (P_CODE) of 13-Q2/P2 and 23109-HB?
--Show customer codes, customer first names, and customer last names in the result set
--Show the total product quantities for each of the products aliased as follows:
--Alias 13-Q2/P2 total quantity as: _13_Q2P2_Qty
--Alias 23109-HB total quantity as: _23109-HB_Qty
--Note: check the BigQuery documentation or error codes to know why we started the alias with an underscore
--Sort the customers by CUS_CODE in ascending order
--Use in-line views to answer this question
SELECT
cust.CUS_CODE,
cust.cus_lname,
cust.cus_fname,
prod1._13_Q2P2_Qty,
prod2._23109_HB_Qty
FROM
`brjo4089.SaleCo.customer` AS cust
INNER JOIN

(SELECT
inv.cus_code,
line.p_code,
SUM(line.line_units) AS _13_Q2P2_Qty
FROM
`brjo4089.SaleCo.invoice` AS inv
INNER JOIN
`brjo4089.SaleCo.line` AS line
ON
inv.INV_NUMBER = line.INV_NUMBER
WHERE
line.p_code = '13-Q2/P2'
GROUP BY
inv.cus_code,
line.P_CODE
) AS prod1

ON cust.cus_code = prod1.cus_code

INNER JOIN
(SELECT
inv.cus_code,
line.p_code,
SUM (line.line_units) AS _23109_HB_Qty 

FROM
`brjo4089.SaleCo.invoice` AS inv
INNER JOIN
`brjo4089.SaleCo.line` AS line
ON
inv.inv_number = line.INV_NUMBER
WHERE
line.p_code = '23109-HB'
GROUP BY
inv.cus_code,
line.p_code) AS prod2
ON
prod1.cus_code= prod2.cus_code
ORDER BY
cust.cus_code
;
