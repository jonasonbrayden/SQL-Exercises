#In Line View
# Who are the customers that have purchased two specific products?
SELECT DISTINCT
  cust.cus_code, 
  cust.cus_lname
FROM 
  `brjo4089.SaleCo.customer` as cust
  INNER JOIN 
    (SELECT 
      invoice.cus_code
      FROM
      `brjo4089.SaleCo.invoice` as invoice
      INNER JOIN
      `brjo4089.SaleCo.line` as line
      ON
      invoice.inv_number = line.inv_number
      WHERE
      line.p_code = '13-Q2/P2') as CustProd1
      ON
      cust.cus_code = CustProd1.cus_code

  INNER JOIN
    (SELECT 
      invoice.cus_code
      FROM
      `brjo4089.SaleCo.invoice` as invoice
      INNER JOIN
      `brjo4089.SaleCo.line` as line
      ON
      invoice.inv_number = line.inv_number
      WHERE
      line.p_code = '23109-HB') as CustProd2
      ON
      CustProd1.cus_code = CustProd2.cus_code
      ;

