#What are all the products with inventory levels below the average inventory levels?

SELECT prod.p_code, prod.p_descript,
vend.v_code, vend.v_name, vend.v_contact,
prod.p_qoh,

(SELECT round(avg(prod.p_qoh),2) from `brjo4089.SaleCo.product` as prod) as avgProdInventory,

round(prod.p_qoh - (SELECT avg(p_qoh) from `brjo4089.SaleCo.product` as prod),2) as invAvgDiff

FROM `brjo4089.SaleCo.product` as prod
LEFT JOIN
`brjo4089.SaleCo.vendor` as vend
ON
prod.v_code = vend.v_code

GROUP BY
prod.p_code, prod.p_descript, prod.p_qoh,
vend.v_code, vend.v_name, vend.v_contact

HAVING
invAvgDiff < 0

ORDER BY
invAvgDiff
;
#What is the total order quantity for all orders compared to the overall company total quantity and overall company average quantity? 

SELECT
ordI.order_num, sum(ordI.quantity) as ordTotal,

#subquery one to get total quantity for all orders
(SELECT
sum(ordI.quantity)
FROM
`styssql.order_items` as ordI
) as totQty,

#subquery two to get average quantity for all orders
(SELECT
round(SUM(ordI.quantity)/(COUNT(DISTINCT order_num)),2)
FROM
`styssql.order_items` as ordI
) as avgQty
;
# Q5:What products have inventory (P_QOH) but haven't been sold? 
SELECT
  prod.P_CODE,
  prod.P_QOH,
  vend.V_NAME
FROM
  `brjo4089.SaleCo.vendor` AS vend
INNER JOIN
  `brjo4089.SaleCo.product` AS prod
ON 
  vend.V_CODE = prod.V_CODE

WHERE
  vend.V_ORDER IS false
ORDER BY
  prod.P_QOH,
  prod.P_CODE DESC

;
#Q6:What products have inventory (P_QOH) but haven't been sold? 
SELECT
  prod.P_CODE,
  prod.P_QOH,
  vend.V_NAME,
  lin.INV_NUMBER
FROM
  `brjo4089.SaleCo.vendor` AS vend
LEFT JOIN
  `brjo4089.SaleCo.product` AS prod
ON 
  vend.V_CODE = prod.V_CODE
LEFT JOIN
  `brjo4089.SaleCo.line` AS lin
ON
  prod.P_CODE = lin.p_code
WHERE
  INV_NUMBER IS NULL
ORDER BY
  prod.P_QOH,
  prod.P_CODE DESC
;
#What are all the customer numbers that ordered the product 'BR01'?
SELECT
  cust.cust_id AS customernum
  FROM
  `brjo4089.styssql.customers` AS cust
  WHERE
    cust.cust_id IN
    (SELECT ord.cust_id
    FROM `brjo4089.styssql.orders` AS ord
    WHERE ord.order_num
    IN
      (SELECT ordi.order_num
      FROM `brjo4089.styssql.order_items` AS ordi
      WHERE ordi.prod_id= 'BR01'
      )
    )
;
#What is the average price of our products?
SELECT
CONCAT('$', ROUND(AVG(prod.prod_price),2)) AS avgPrice
FROM
  `brjo4089.styssql.products` AS prod
;
#What is our minimum , average, and maximum prices for all products?
SELECT
  COUNT(*) AS totRows,
  COUNT(prod.prod_id) AS totProds,
  ROUND(MIN(prod.prod_price),2) AS minPrice,
  ROUND(AVG(prod.prod_price), 2) AS avgPrice,
  ROUND(MAX(prod.prod_price),2) AS maxPrice
FROM
  `brjo4089.styssql.products` AS prod
;
#What are the vendors names and countries?
# Combing fields using concat
SELECT
vend.vend_name,
vend.vend_country,
CONCAT(vend.vend_name, '', '(', vend.vend_country, ')') AS vendCountry
FROM
  `brjo4089.styssql.vendors` AS vend
;
#What are the first four letters in each vendors name?
SELECT
vend.vend_name,
LEFT(vend.vend_name, 4) AS vend_first4
FROM
  `brjo4089.styssql.vendors` AS vend
;
#What is the expanded/total price for all products for our ordered items?
SELECT
ordI.order_num,
ordI.prod_id,
ordI.quantity,
ordI.item_price,
ordI.quantity* ordI.item_price AS total_price
FROM
  `brjo4089.styssql.order_items` AS ordI
ORDER BY
total_price DESC
;
#What are all the orders that took place in 2012?
SELECT
o.order_num,
o.order_date,
EXTRACT(YEAR FROM o.order_date) AS year
FROM
  `brjo4089.styssql.orders` AS o
WHERE
EXTRACT(YEAR FROM o.order_date)= 2012

