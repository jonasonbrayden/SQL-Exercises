# What are all the orders in our database?
SELECT
cust.cust_name,
ord.order_num,
ordi.order_item,
prod.prod_id,
prod.prod_name,
vend.vend_name

FROM
  `brjo4089.styssql.customers` AS cust
  INNER JOIN
   `brjo4089.styssql.orders` AS ord
   ON
   cust.cust_id= ord.cust_id
  INNER JOIN
  `brjo4089.styssql.order_items` AS ordi
  ON
  ord.order_num = ordi.order_num
  INNER JOIN
  `brjo4089.styssql.products` AS prod
  ON
  prod.prod_id = ordi.prod_id
  INNER JOIN
  `brjo4089.styssql.vendors` AS vend
  ON
  vend.vend_id= prod.vend_id
  ORDER BY
  cust.cust_name,
  prod.prod_name
  ;
  #What was the total order quantity for each vendor?
SELECT
vend.vend_id,
vend.vend_name,
SUM(ordi.quantity) AS vend_qty
FROM
  `brjo4089.styssql.order_items` AS ordi
  INNER JOIN
  `brjo4089.styssql.products` AS prod
  ON
  prod.prod_id = ordi.prod_id
  INNER JOIN
  `brjo4089.styssql.vendors` AS vend
  ON
  vend.vend_id= prod.vend_id
GROUP BY
vend.vend_id,
vend.vend_name
ORDER BY
vend_qty DESC
;
#: What vendors (vend_id) have an average product price greater than $9 when only considering product prices greater than $4?
SELECT
prod.vend_id,
AVG(prod.prod_price) AS AVGover4
FROM
  `brjo4089.styssql.products` AS prod
WHERE
  prod.prod_price > 4
GROUP BY
  vend_id
HAVING
AVGover4 > 9
;
